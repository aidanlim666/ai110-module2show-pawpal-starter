classDiagram
    class Task {
        +str title
        +int duration_minutes
        +str priority
        +str category
        +str fixed_time
        +bool is_recurring
        +str frequency
        +bool completed
        +date due_date
        +mark_complete() Task
        +next_occurrence() Task
        +priority_value() int
        +is_fixed_time() bool
        +fits_in(available_minutes) bool
    }

    class Pet {
        +str name
        +str species
        +list tasks
        +add_task(task)
        +remove_task(title)
        +get_tasks() list
    }

    class Owner {
        +str name
        +int available_minutes
        +str day_start
        +list pets
        +add_pet(pet)
        +get_pet(name) Pet
        +get_tasks(pet_name, completed) list
    }

    class Scheduler {
        +schedule_day(pet, owner) DailySchedule
        +sort_by_time(tasks) list
        +check_conflicts(schedules) list
        -_sort_by_priority(tasks) list
        -_place_fixed_tasks(tasks, day_start) list
        -_fill_remaining(tasks, fixed_entries, remaining_minutes, day_start) list
        -_detect_conflicts(entries) list
        -_build_reason(task, position) str
    }

    class ScheduledEntry {
        +Task task
        +str start_time
        +str end_time
        +str reason
    }

    class DailySchedule {
        +str pet_name
        +str owner_name
        +str date
        +list entries
        +list skipped_tasks
        +int total_duration_minutes
        +add_entry(entry)
        +get_summary() str
        +explain() str
    }

    Owner "1" --> "1..*" Pet : has
    Pet "1" --> "0..*" Task : has
    Owner ..> Task : get_tasks() queries across pets
    Scheduler ..> Pet : reads
    Scheduler ..> Owner : reads
    Scheduler ..> DailySchedule : produces / checks
    DailySchedule "1" --> "0..*" ScheduledEntry : contains
    ScheduledEntry --> Task : references
    Task ..> Task : mark_complete() creates next occurrence
